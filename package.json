{
    "name": "shinaa-monorepo",
    "private": true,
    "workspaces": [
      "apps/*",
      "packages/*"
    ],
    "scripts": {
      "db:up": "docker compose up -d",
      "db:down": "docker compose down",
      "db:push": "bun x prisma@5.14.0 db push --schema=packages/database/prisma/schema.prisma --skip-generate",
      "db:seed": "bun --env-file=.env packages/database/prisma/seed.ts",
      "create-admin": "bun run --cwd apps/api scripts/create-admin.ts",
      "dev": "concurrently \"bun --filter @shinaa/api dev\" \"bun --filter @shinaa/web-dashboard dev\" \"npm run --prefix apps/mobile-app start\"",
      "ts:check": "concurrently \"bun run --cwd apps/api build\" \"bun run --cwd apps/web-dashboard build\" \"bun run --cwd apps/mobile-app ts:check\""
    },
    "devDependencies": {
      "concurrently": "^8.2.2",
      "typescript": "^5.4.5"
    },
    "resolutions": {
      "expo": "56.0.12",
      "expo-asset": "56.0.17",
      "expo-constants": "56.0.18",
      "expo-font": "56.0.7",
      "expo-linking": "56.0.14",
      "expo-router": "56.2.11",
      "expo-secure-store": "56.0.4",
      "expo-status-bar": "56.0.4",
      "react-native": "0.85.3",
      "react-native-safe-area-context": "5.7.0",
      "react-native-screens": "4.25.2",
      "@expo/dom-webview": "56.0.5",
      "@expo/log-box": "56.0.13",
      "react": "19.2.3",
      "react-dom": "19.2.3"
    }
  }
